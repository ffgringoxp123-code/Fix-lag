-- Dragging functionality
Content.InputBegan:Connect(function(input)
  if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
    dragToggle = true
    dragStart = input.Position
    startPos = Content.Position
    input.Changed:Connect(function()
      if input.UserInputState == Enum.UserInputState.End then
        dragToggle = false
      end
    end)
  end
end)

Content.InputChanged:Connect(function(input)
  if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
    if dragToggle then
      local delta = input.Position - dragStart
      Content.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
      )
    end
  end
end)

-- Resize functionality (kéo góc dưới phải)
local Resizer = Instance.new("ImageButton")
Resizer.BackgroundTransparency = 1
Resizer.Image = "rbxassetid://4312464743" -- resize icon
Resizer.Size = UDim2.fromScale(0.08, 0.08)
Resizer.Position = UDim2.fromScale(0.92, 0.92)
Resizer.Parent = Content

local resizeToggle = false
local resizeStart = nil
local resizeStartSize = nil

Resizer.InputBegan:Connect(function(input)
  if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
    resizeToggle = true
    resizeStart = input.Position
    resizeStartSize = Content.Size
    input.Changed:Connect(function()
      if input.UserInputState == Enum.UserInputState.End then
        resizeToggle = false
      end
    end)
  end
end)

Resizer.InputChanged:Connect(function(input)
  if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
    if resizeToggle then
      local delta = input.Position - resizeStart
      local newX = math.max(0.1, resizeStartSize.X.Scale + delta.X * 0.001)
      local newY = math.max(0.1, resizeStartSize.Y.Scale + delta.Y * 0.001)
      Content.Size = UDim2.fromScale(newX, newY)
    end
  end
end)

local IsActive = false

Toggler.MouseButton1Click:Connect(function()
  Toggler.Interactable = false
  if IsActive then
    Toggler.Text = "Off"
    Toggler.BackgroundColor3 = Color3.fromRGB(255, 105, 180) -- hồng
    VFX.Enabled = false
    Settings.IncomingReplicationLag = 0
    IsActive = false
  else
    Toggler.Text = "On"
    Toggler.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- xanh khi bật
    VFX.Enabled = true
    Settings.IncomingReplicationLag = 1000
    IsActive = true
  end
  Toggler.Interactable = true
end)
